params {
  outdir          = 'results'
  metrics_dir     = 'metrics'
  work_dir        = 'work'
  n_windows       = 1250
  queue_size      = 480

  ref_fa          = "${params.outdir}/reference/genome.fa"
  ref_bed         = "${params.outdir}/reference/genome_annotations.bed"
  manifest_tsv    = "${params.outdir}/manifests/window_manifest.tsv"
  trace_file      = "${params.outdir}/pipeline_info/execution_trace.txt"
  merged_csv      = "${params.outdir}/pipeline_info/merged_audit_trace.csv"
  merged_tsv      = "${params.outdir}/pipeline_info/merged_audit_trace.tsv"

  ref_cpus        = 1
  ref_memory      = '1 GB'
  ref_time        = '1h'

  plan_cpus       = 1
  plan_memory     = '1 GB'
  plan_time       = '30m'

  reads_cpus      = 1
  reads_memory    = '1 GB'
  reads_time      = '1h'

  index_cpus      = 2
  index_memory    = '2 GB'
  index_time      = '1h'

  map_cpus        = 1
  map_memory      = '4 GB'
  map_time        = '1h'

  bam_index_cpus  = 1
  bam_index_memory= '1 GB'
  bam_index_time  = '1h'

  flagstat_cpus   = 1
  flagstat_memory = '1 GB'
  flagstat_time   = '1h'
}

workDir = params.work_dir

process {
  errorStrategy = 'retry'
  maxRetries    = 5
  cache         = 'lenient'
}

executor {
  queueSize = params.queue_size
}

trace {
  enabled   = true
  file      = params.trace_file
  overwrite = true
  fields    = 'task_id,hash,native_id,process,tag,name,status,exit,cpus,time,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,syscr,syscw,read_bytes,write_bytes,workdir'
}

report {
  enabled   = true
  file      = "${params.outdir}/pipeline_info/execution_report.html"
  overwrite = true
}

timeline {
  enabled   = true
  file      = "${params.outdir}/pipeline_info/execution_timeline.html"
  overwrite = true
}

dag {
  enabled   = true
  file      = "${params.outdir}/pipeline_info/flowchart.dot"
  overwrite = true
}

profiles {
  local {
    process.executor = 'local'
  }

  slurm {
    process.executor = 'slurm'
    process.queue    = 'compute'
  }
}
