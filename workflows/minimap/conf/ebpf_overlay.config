/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Per-task eBPF tracing overlay for the Minimap2 audit workflow
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Mirrors the working mcmicro pattern:
      - run pipeline as root
      - stop the live task shell
      - attach /shared/08_ebpf_audit.py to that PID
      - wait for ready-file handshake
      - resume task and wait for tracer to flush TSV
----------------------------------------------------------------------------------------
*/

process {
    beforeScript = {
        def proc_name = task.process.tokenize(':')[-1]
        def trace_dir = "${params.outdir}/ebpf/${proc_name}/task_${task.hash}"
        """
        if [[ \$(id -u) -ne 0 ]]; then
            echo "ERROR: eBPF tracing requires running this pipeline as root." >&2
            exit 1
        fi

        need_install=0
        if ! command -v minimap2 >/dev/null 2>&1; then
            need_install=1
        fi
        if ! command -v samtools >/dev/null 2>&1; then
            need_install=1
        fi
        if ! /usr/bin/python3 -c "from bcc import BPF" >/dev/null 2>&1; then
            need_install=1
        fi

        if [[ "\$need_install" -eq 1 ]]; then
            exec 9>/tmp/minimap2_audit_tools_install.lock
            flock 9
            need_install=0
            if ! command -v minimap2 >/dev/null 2>&1; then
                need_install=1
            fi
            if ! command -v samtools >/dev/null 2>&1; then
                need_install=1
            fi
            if ! /usr/bin/python3 -c "from bcc import BPF" >/dev/null 2>&1; then
                need_install=1
            fi
            if [[ "\$need_install" -eq 1 ]]; then
                apt-get update
                apt-get install -y \
                    minimap2 \
                    samtools \
                    bpfcc-tools \
                    python3-bpfcc \
                    linux-headers-\$(uname -r)
            fi
        fi

        command -v minimap2 >/dev/null 2>&1 || {
            echo "ERROR: minimap2 is still unavailable on \$(hostname)." >&2
            exit 1
        }

        command -v samtools >/dev/null 2>&1 || {
            echo "ERROR: samtools is still unavailable on \$(hostname)." >&2
            exit 1
        }

        /usr/bin/python3 -c "from bcc import BPF" >/dev/null 2>&1 || {
            echo "ERROR: python3-bpfcc/BCC is still unavailable on \$(hostname)." >&2
            exit 1
        }

        mkdir -p "${trace_dir}"
        echo \$\$ > "${trace_dir}/wrapper_pid.txt"

        __nxf_launch_def="\$(declare -f nxf_launch)"
        eval "\$(printf '%s\\n' "\$__nxf_launch_def" | sed '1s/nxf_launch/nxf_launch_orig/')"
        export -f nxf_launch_orig

        nxf_launch() {
            local ready_file="${trace_dir}/audit_ready.txt"
            rm -f "\$ready_file"

            _ebpf_launch_wrapper() {
                kill -STOP "\$BASHPID"
                nxf_launch_orig
            }

            _ebpf_launch_wrapper &
            local launch_pid=\$!
            echo \$launch_pid > "${trace_dir}/task_pid.txt"

            /usr/bin/python3 ${workflow.projectDir}/tools/ebpf_audit.py \\
                --pid "\$launch_pid" \\
                --ready-file "\$ready_file" \\
                --outdir "${trace_dir}" \\
                > "${trace_dir}/audit_stdout.log" \\
                2> "${trace_dir}/audit_stderr.log" < /dev/null &
            local audit_pid=\$!
            echo \$audit_pid > "${trace_dir}/audit_launcher_pid.txt"

            while [[ ! -f "\$ready_file" ]]; do
                if ! kill -0 "\$audit_pid" 2>/dev/null; then
                    echo "ERROR: eBPF tracer exited before it reported readiness." >&2
                    wait "\$audit_pid" || true
                    kill -CONT "\$launch_pid" 2>/dev/null || true
                    wait "\$launch_pid" || true
                    return 1
                fi
                sleep 0.1
            done

            kill -CONT "\$launch_pid"
            local launch_status=0
            wait "\$launch_pid" || launch_status=\$?
            wait "\$audit_pid" || true
            return \$launch_status
        }
        """
    }
}
