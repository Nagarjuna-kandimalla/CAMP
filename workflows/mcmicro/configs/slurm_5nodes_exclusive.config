/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Slurm overlay for nf-core/mcmicro using up to 5 exclusive compute nodes
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    This is for workflow execution on Slurm. It does not enable per-task eBPF
    tracing by itself; root/privileged access on compute nodes would still be
    required for that.
----------------------------------------------------------------------------------------
*/

process {
    executor = 'slurm'
    queue = 'compute'

    /*
     * At most 5 tasks can run concurrently. Combined with --exclusive and the
     * task-level resource requests, Slurm can spread them across up to 5 nodes.
     * This does not force exactly 5 nodes to be occupied at all times.
     */
    queueSize = 5
    clusterOptions = '--exclusive'
}

apptainer.enabled    = true
apptainer.autoMounts = true
docker.enabled       = false
podman.enabled       = false
singularity.enabled  = false
conda.enabled        = false
