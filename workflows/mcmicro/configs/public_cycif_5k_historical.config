/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Public CyCIF config for ~5k mcmicro task instances
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_name        = 'Public CyCIF 5k task profile'
    config_profile_description = 'Local public CyCIF data sized to yield about 5k task instances'

    input_cycle  = "/shared/mcmicro/assets/samplesheet-public-cycif-5k.csv"
    marker_sheet = "${projectDir}/assets/markers-test_full.csv"

    illumination = "basicpy"
    segmentation = "mesmer,cellpose"
    backsub      = true
}

process {
    withName: ".*:DEEPCELL_MESMER" {
        memory = "6.GB"
        cpus = 2
        errorStrategy = 'retry'
        maxRetries = 5
        containerOptions = {
            def kerasCache = System.getenv('MCMICRO_KERAS_CACHE_DIR')
            kerasCache ? "--bind ${kerasCache}:/root/.keras:ro --env MPLCONFIGDIR=/tmp/mplconfig" : ''
        }
    }
    withName: '.*:CELLPOSE' {
        memory = "12.GB"
        cpus   = 4
    }
}
