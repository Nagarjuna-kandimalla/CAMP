/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Selective per-task eBPF tracing overlay for the Bowtie2 audit workflow
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    camp_task_plan = null
    camp_run_with_optional_audit = null
    camp_ebpf_tracer = null
}

process {
    beforeScript = {
        def proc_name = task.process.tokenize(':')[-1]
        def trace_dir = "${params.outdir}/ebpf/${proc_name}/task_${task.hash}"
        def task_plan = params.camp_task_plan ?: ''
        def wrapper = params.camp_run_with_optional_audit ?: ''
        def tracer = params.camp_ebpf_tracer ?: ''
        def metrics_dir = params.metrics_dir ?: "${params.outdir}/metrics"
        """
        [[ -n "${task_plan}" ]] || { echo "ERROR: set --camp_task_plan to the gating task-plan CSV." >&2; exit 1; }
        [[ -n "${wrapper}" ]] || { echo "ERROR: set --camp_run_with_optional_audit to the artifact-local wrapper path." >&2; exit 1; }
        [[ -n "${tracer}" ]] || { echo "ERROR: set --camp_ebpf_tracer to the artifact-local ebpf_audit.py path." >&2; exit 1; }
        [[ -f "${task_plan}" ]] || { echo "ERROR: task plan not found: ${task_plan}" >&2; exit 1; }
        [[ -f "${wrapper}" ]] || { echo "ERROR: wrapper not found: ${wrapper}" >&2; exit 1; }
        [[ -f "${tracer}" ]] || { echo "ERROR: tracer not found: ${tracer}" >&2; exit 1; }

        mkdir -p "${trace_dir}" "${metrics_dir}"
        echo \$\$ > "${trace_dir}/wrapper_pid.txt"

        __nxf_launch_def="\$(declare -f nxf_launch)"
        eval "\$(printf '%s\\n' "\$__nxf_launch_def" | sed '1s/nxf_launch/nxf_launch_orig/')"
        export -f nxf_launch_orig

        nxf_launch() {
            /usr/bin/python3 "${wrapper}" \\
                --task-plan "${task_plan}" \\
                --task-type "${proc_name}" \\
                --task-instance "${task.hash}" \\
                --metrics-dir "${metrics_dir}" \\
                --ebpf-script "${tracer}" \\
                --ebpf-outdir "${trace_dir}" \\
                -- bash -lc 'nxf_launch_orig'
        }
        """
    }
}
